import java.util.Scanner;

public class NotebookCount {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.print("Enter pulp in kg (N): ");
        int N = input.nextInt();

        int notebooks = N * 10;

        System.out.println("Total notebooks: " + notebooks);

        input.close();
    }
}
