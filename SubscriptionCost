import java.util.Scanner;

public class SubscriptionCost {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.print("Enter number of friends (N): ");
        int N = input.nextInt();

        System.out.print("Enter cost per subscription (X): ");
        int X = input.nextInt();

        int subscriptions = (N + 5) / 6; // ceiling division
        int totalCost = subscriptions * X;

        System.out.println("Minimum total cost: " + totalCost);

        input.close();
    }
}
